{
  "schemaVersion": "protocol-lab.load-profile.v1",
  "id": "quic-diagnostic",
  "title": "QUIC Diagnostic",
  "status": "stable",
  "purpose": "diagnostic",
  "description": "Short protocol-specific diagnostic profile for validation evidence and optional protocol artifacts. Not publishable benchmark evidence by itself.\n",
  "durationSeconds": 10,
  "warmupSeconds": 1,
  "cooldownSeconds": 1,
  "repetitions": 1,
  "quic": {
    "connections": 1,
    "streamsPerConnection": 16,
    "streamBytes": 1024,
    "connectionTimeoutSeconds": 10,
    "idleTimeoutSeconds": 10
  },
  "evidence": {
    "minimumTier": "diagnostic",
    "publishable": false
  },
  "artifacts": {
    "required": [
      "load.stdout.log",
      "load.stderr.log",
      "validation.json",
      "result.json"
    ],
    "optional": [
      "counters",
      "protocol-diagnostic-artifact",
      "telemetry-bundle.json"
    ]
  }
}
