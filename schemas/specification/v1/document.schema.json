{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.incursa.com/protocol-lab/specification/v1/document.schema.json",
  "title": "ProtocolLab Specification Document v1",
  "description": "Immutable identity and review metadata for an external specification source used by ProtocolLab coverage mappings.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "documentId",
    "title",
    "publisher",
    "canonicalUrl",
    "protocols",
    "documentKind",
    "publicationStatus",
    "reviewState"
  ],
  "properties": {
    "schemaVersion": { "const": "protocol-lab.specification-document.v1" },
    "documentId": { "$ref": "#/$defs/token" },
    "title": { "$ref": "#/$defs/nonEmptyString" },
    "publisher": { "$ref": "#/$defs/nonEmptyString" },
    "canonicalUrl": { "type": "string", "format": "uri" },
    "protocols": { "$ref": "#/$defs/nonEmptyTokenArray" },
    "documentKind": { "type": "string", "enum": ["rfc", "internet-draft", "standard", "extension"] },
    "publicationStatus": { "type": "string", "enum": ["draft", "published", "obsoleted", "withdrawn"] },
    "publicationDate": { "type": "string", "format": "date" },
    "exactRevision": { "type": "string", "minLength": 1 },
    "sourceFormat": { "type": "string", "enum": ["rfcxml", "xml", "json", "markdown", "text"] },
    "contentSha256": { "$ref": "#/$defs/sha256" },
    "updates": { "$ref": "#/$defs/tokenArray" },
    "obsoletes": { "$ref": "#/$defs/tokenArray" },
    "errata": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["erratumId", "status"],
        "properties": {
          "erratumId": { "$ref": "#/$defs/token" },
          "status": { "type": "string", "enum": ["reported", "verified", "held", "rejected"] },
          "url": { "type": "string", "format": "uri" }
        }
      }
    },
    "reviewState": { "$ref": "#/$defs/reviewState" },
    "reviewedAt": { "type": "string", "format": "date-time" },
    "reviewedBy": { "type": "string", "minLength": 1 },
    "notes": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "properties": { "documentKind": { "const": "internet-draft" } }, "required": ["documentKind"] },
      "then": { "required": ["exactRevision"] }
    }
  ],
  "$defs": {
    "token": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$" },
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "reviewState": { "type": "string", "enum": ["proposed", "reviewed", "approved", "deprecated"] },
    "tokenArray": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/token" } },
    "nonEmptyTokenArray": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/token" } }
  }
}
