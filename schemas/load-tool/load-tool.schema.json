{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://protocol-lab.incursa.com/schemas/load-tool.schema.json",
  "title": "ProtocolLab Load Tool v1",
  "description": "Schema for ProtocolLab load tool definition files.",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "title",
    "kind",
    "supports"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Schema version identifier (e.g., protocol-lab.load-tool.v1)",
      "pattern": "^protocol-lab\\.load-tool\\.v[0-9]+$"
    },
    "id": {
      "type": "string",
      "description": "Stable load tool ID (e.g., h2load, oha, managed-httpclient-h3-load)",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "description": "Human-readable load tool title"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the load tool"
    },
    "name": {
      "type": "string",
      "description": "Legacy display name"
    },
    "kind": {
      "type": "string",
      "description": "Load tool execution kind",
      "enum": ["managed", "process", "docker"]
    },
    "category": {
      "type": "string",
      "description": "Load tool category",
      "enum": ["external-reference", "managed-lab", "experimental"]
    },
    "supports": {
      "type": "object",
      "description": "Capability declaration",
      "required": ["protocols", "trafficShapes", "roles"],
      "properties": {
        "protocols": {
          "type": "array",
          "description": "Supported protocols",
          "items": { "type": "string" },
          "minItems": 1
        },
        "trafficShapes": {
          "type": "array",
          "description": "Supported traffic shapes",
          "items": {
            "type": "string",
            "enum": [
              "request-response",
              "requestResponse",
              "upload",
              "download",
              "streaming-download",
              "streamingDownload",
              "streaming-upload",
              "streamingUpload",
              "bidirectional-stream",
              "bidirectionalStream",
              "datagram",
              "handshake-only",
              "handshakeOnly",
              "connection-lifecycle",
              "connectionLifecycle"
            ]
          },
          "minItems": 1
        },
        "roles": {
          "type": "array",
          "description": "Supported roles",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "metrics": {
      "type": "object",
      "description": "Declared metric names",
      "properties": {
        "primary": {
          "type": "array",
          "description": "Primary metrics (comparable across tools)",
          "items": { "type": "string" }
        },
        "secondary": {
          "type": "array",
          "description": "Secondary metrics (tool-specific)",
          "items": { "type": "string" }
        }
      }
    },
    "execution": {
      "type": "object",
      "description": "Execution configuration",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "process": {
              "type": "object",
              "description": "Process execution configuration",
              "properties": {
                "executable": { "type": "string" },
                "defaultArguments": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "versionCommand": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "availabilityCheck": { "type": "string" }
              }
            }
          },
          "required": ["process"]
        },
        {
          "type": "object",
          "properties": {
            "docker": {
              "type": "object",
              "description": "Docker execution configuration",
              "properties": {
                "image": { "type": "string" },
                "commandTemplate": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "command": { "type": "string" },
                "arguments": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "environment": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "autoPull": { "type": "boolean" },
                "hostRewrite": { "type": "string" },
                "sni": { "type": "string" }
              }
            }
          },
          "required": ["docker"]
        }
      ]
    },
    "parser": {
      "type": "object",
      "description": "Output parser configuration",
      "properties": {
        "type": {
          "type": "string",
          "description": "Parser type identifier"
        },
        "id": {
          "type": "string",
          "description": "Legacy parser identifier"
        },
        "preservesRawOutput": {
          "type": "boolean",
          "description": "Whether raw tool output is preserved alongside parsed metrics"
        }
      },
      "required": ["type"]
    },
    "artifacts": {
      "type": "object",
      "description": "Declared artifact paths",
      "properties": {
        "required": {
          "type": "array",
          "items": { "type": "string" }
        },
        "optional": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "purposes": {
      "type": "array",
      "description": "Supported benchmark purposes",
      "items": {
        "type": "string",
        "enum": ["validation", "benchmark", "profile", "diagnostic"]
      }
    },
    "limitations": {
      "type": "array",
      "description": "Known limitations",
      "items": { "type": "string" }
    },
    "executable": {
      "type": "string",
      "description": "Legacy executable path"
    },
    "dockerImage": {
      "type": "string",
      "description": "Legacy Docker image"
    },
    "dockerCommand": {
      "type": "string",
      "description": "Legacy Docker command"
    },
    "dockerArguments": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Legacy Docker arguments"
    },
    "dockerEnvironment": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Legacy Docker environment"
    },
    "dockerAutoPull": {
      "type": "boolean",
      "description": "Legacy Docker auto-pull flag"
    },
    "dockerHostRewrite": {
      "type": "string",
      "description": "Legacy Docker host rewrite"
    },
    "sni": {
      "type": "string",
      "description": "Legacy SNI value"
    },
    "defaultArguments": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Legacy default arguments"
    },
    "versionCommand": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Legacy version command"
    },
    "availabilityCheck": {
      "type": "string",
      "description": "Legacy availability check method"
    },
    "outputParserId": {
      "type": "string",
      "description": "Legacy output parser identifier"
    },
    "notes": {
      "type": "string",
      "description": "Free-form notes"
    },
    "supportedProtocols": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Legacy supported protocols list"
    },
    "supportedScenarioFamilies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Legacy supported scenario families"
    }
  }
}
