{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.incursa.com/protocol-lab/measurement/v1/measurement-summary.schema.json",
  "title": "ProtocolLab Measurement Summary v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary_id", "metric_name", "scope", "source", "unit", "provenance"],
  "properties": {
    "summary_id": { "type": "string", "minLength": 1 },
    "metric_name": { "type": "string", "minLength": 1 },
    "summary_kind": {
      "type": "string",
      "enum": ["latency", "throughput", "errors", "resource", "load-shape", "protocol", "other"]
    },
    "scope": {
      "type": "string",
      "enum": ["runner", "implementation", "test-executor", "load-generator", "environment", "protocol", "artifact", "other"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["runner", "implementation", "test-executor", "load-generator", "environment", "protocol", "artifact", "other"]
        },
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "telemetry_system": { "type": "string", "minLength": 1 }
      }
    },
    "count": { "type": "integer", "minimum": 0 },
    "min": { "type": "number" },
    "max": { "type": "number" },
    "mean": { "type": "number" },
    "p50": { "type": "number" },
    "p90": { "type": "number" },
    "p95": { "type": "number" },
    "p99": { "type": "number" },
    "stddev": { "type": "number", "minimum": 0 },
    "unit": { "type": "string", "minLength": 1 },
    "requests_total": { "type": "integer", "minimum": 0 },
    "requests_per_second": { "type": "number", "minimum": 0 },
    "errors_total": { "type": "integer", "minimum": 0 },
    "timeouts_total": { "type": "integer", "minimum": 0 },
    "non_success_status_total": { "type": "integer", "minimum": 0 },
    "window_start_utc": { "type": "string", "format": "date-time" },
    "window_end_utc": { "type": "string", "format": "date-time" },
    "aggregation": { "type": "string", "minLength": 1 },
    "tags": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "required": ["observed_by", "method"],
      "properties": {
        "observed_by": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "confidence": {
          "type": "string",
          "enum": ["declared", "observed", "derived", "estimated", "unknown"]
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
