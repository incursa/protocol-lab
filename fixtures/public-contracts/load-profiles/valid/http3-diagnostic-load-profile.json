{
  "schemaVersion": "protocol-lab.load-profile.v1",
  "id": "http3-diagnostic",
  "title": "HTTP/3 Diagnostic",
  "status": "stable",
  "purpose": "diagnostic",
  "description": "Short protocol-specific diagnostic profile for validation evidence and optional protocol artifacts. Not publishable benchmark evidence by itself.\n",
  "durationSeconds": 10,
  "warmupSeconds": 1,
  "cooldownSeconds": 1,
  "repetitions": 1,
  "http3": {
    "connections": 1,
    "concurrency": 8,
    "streamsPerConnection": 8,
    "requestTimeoutSeconds": 10
  },
  "evidence": {
    "minimumTier": "diagnostic",
    "publishable": false
  },
  "artifacts": {
    "required": [
      "load.stdout.log",
      "load.stderr.log",
      "validation.json",
      "result.json"
    ],
    "optional": [
      "counters",
      "protocol-diagnostic-artifact",
      "telemetry-bundle.json"
    ]
  }
}
