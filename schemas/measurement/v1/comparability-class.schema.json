{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.incursa.com/protocol-lab/measurement/v1/comparability-class.schema.json",
  "title": "ProtocolLab Comparability Class v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["class", "statement"],
  "properties": {
    "class": {
      "type": "string",
      "enum": ["none", "same-run", "same-profile", "same-environment", "lab-controlled", "public-reference"]
    },
    "statement": {
      "type": "string",
      "minLength": 1,
      "description": "Evidence statement explaining what comparisons this result can support."
    },
    "basis": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
