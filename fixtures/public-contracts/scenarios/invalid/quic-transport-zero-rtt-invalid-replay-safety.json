{
  "schemaVersion": "1.0",
  "id": "quic.transport.zero-rtt-invalid",
  "title": "QUIC 0-RTT Invalid Replay Safety",
  "name": "QUIC 0-RTT Invalid Replay Safety",
  "family": "quic.transport",
  "description": "Invalid example that uses an unsupported replay-safety enum value in QUIC session metadata.",
  "status": "stable",
  "kind": "protocolValidation",
  "layer": "transport",
  "protocol": "quic",
  "roles": [
    "server"
  ],
  "requires": {
    "capabilities": [
      "quic.server",
      "quic.resumption",
      "quic.zero-rtt"
    ],
    "protocols": [
      "quic"
    ],
    "roles": [
      "server"
    ]
  },
  "trafficShape": "bidirectional-stream",
  "implementationRole": "server",
  "requiredCapabilities": [
    "quicTransport",
    "quicHandshake",
    "quicResumption",
    "quicZeroRtt"
  ],
  "quicTransport": {
    "behavior": "zero-rtt-accepted",
    "connectionCount": 1,
    "streamType": "bidirectional",
    "streamCount": 1,
    "payloadSizeBytes": 1024,
    "payloadDirection": "client-to-server",
    "openPattern": "sequential",
    "expectedBytes": 1024
  },
  "validation": {
    "required": true,
    "checks": [
      "zero-rtt-accepted",
      "protocol:quic"
    ],
    "quic": {
      "handshakeMustComplete": true,
      "session": {
        "resumptionState": "resumed",
        "earlyData": "accepted",
        "replaySafety": "replay-dangerous"
      }
    }
  }
}
