{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProtocolLab Test Executor Contract v1 Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "executorIdentity",
    "versionCompatibility",
    "claimedCapabilities",
    "supportedTestSelectors",
    "supportedScenarioSelectors",
    "supportedProtocolFamilies",
    "supportedExecutionModes",
    "requiredTargetEndpointBindings",
    "supportedArtifactTypes",
    "metricsAvailability"
  ],
  "properties": {
    "executorIdentity": { "$ref": "./common.schema.json#/$defs/identity" },
    "versionCompatibility": { "$ref": "./common.schema.json#/$defs/versionCompatibility" },
    "claimedCapabilities": {
      "type": "array",
      "items": { "$ref": "./common.schema.json#/$defs/capability" }
    },
    "supportedTestSelectors": {
      "type": "array",
      "items": { "$ref": "./common.schema.json#/$defs/selector" }
    },
    "supportedScenarioSelectors": {
      "type": "array",
      "items": { "$ref": "./common.schema.json#/$defs/selector" }
    },
    "scenarioCoverage": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["supported", "conditional", "partial", "experimental", "unsupported", "compatible-target-unproven"]
          },
          "scenarioId": { "type": "string", "minLength": 1 },
          "reason": { "type": "string" },
          "tests": { "$ref": "./common.schema.json#/$defs/stringArray" },
          "metadata": { "type": "object", "additionalProperties": true }
        }
      },
      "description": "Optional per-scenario coverage summary for executor package discovery."
    },
    "supportedProtocolFamilies": { "$ref": "./common.schema.json#/$defs/stringArray" },
    "supportedExecutionModes": { "$ref": "./common.schema.json#/$defs/stringArray" },
    "requiredTargetEndpointBindings": {
      "type": "array",
      "items": { "$ref": "./common.schema.json#/$defs/endpointBinding" }
    },
    "supportedArtifactTypes": {
      "type": "array",
      "items": { "$ref": "./common.schema.json#/$defs/artifactType" }
    },
    "metricsAvailability": { "$ref": "./common.schema.json#/$defs/metricsAvailability" },
    "defaultArguments": {
      "$ref": "./common.schema.json#/$defs/stringArray",
      "description": "Default command arguments used by implementation-owned executor launchers."
    },
    "parser": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "preservesRawOutput": { "type": "boolean" },
        "metadata": { "type": "object", "additionalProperties": true }
      }
    },
    "telemetry": {
      "$ref": "./common.schema.json#/$defs/telemetryCapability",
      "description": "Optional telemetry bundle and artifact export capability discovery. Absence means no telemetry export is advertised."
    },
    "structuredValidationOutcomes": {
      "$ref": "#/$defs/structuredValidationOutcomes",
      "description": "Optional discovery metadata for exact check-level outcomes. Declaration is capability metadata only and is never evidence that a check passed."
    },
    "externalPeerScenarios": {
      "$ref": "./common.schema.json#/$defs/stringArray",
      "description": "Named external-peer scenarios the executor can drive when interoperating with an implementation endpoint."
    },
    "executionMetadata": {
      "type": "object",
      "additionalProperties": false,
      "description": "Declarative package execution metadata needed to locate implementation-owned runtime assets.",
      "properties": {
        "manifest": {
          "type": "string",
          "minLength": 1,
          "not": {
            "anyOf": [
              { "pattern": "^[A-Za-z]:" },
              { "pattern": "^[A-Za-z][A-Za-z0-9+.-]*:" },
              { "pattern": "^/" },
              { "pattern": "(^|[\\\\/])\\.\\.($|[\\\\/])" }
            ]
          }
        }
      }
    },
    "extensions": { "$ref": "./common.schema.json#/$defs/extensions" }
  },
  "$defs": {
    "token": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$" },
    "nonEmptyTokenArray": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/token" } },
    "structuredValidationOutcomes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersions", "checks"],
      "properties": {
        "schemaVersions": { "$ref": "#/$defs/nonEmptyTokenArray" },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/checkCapability" }
        },
        "compatibleCatalogIds": { "$ref": "#/$defs/nonEmptyTokenArray" },
        "compatibleMappingIds": { "$ref": "#/$defs/nonEmptyTokenArray" },
        "compatibleProfileIds": { "$ref": "#/$defs/nonEmptyTokenArray" },
        "unsupportedChecks": {
          "type": "array",
          "items": { "$ref": "#/$defs/unsupportedCheck" }
        }
      }
    },
    "checkCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkId", "checkVersion", "authority"],
      "properties": {
        "checkId": { "$ref": "#/$defs/token" },
        "checkVersion": { "type": "string", "minLength": 1 },
        "authority": { "type": "string", "enum": ["direct", "inferred", "diagnostic"] },
        "requiredArtifactTypes": { "$ref": "#/$defs/nonEmptyTokenArray" }
      }
    },
    "unsupportedCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkId", "reasonCode", "reason"],
      "properties": {
        "checkId": { "$ref": "#/$defs/token" },
        "reasonCode": { "$ref": "#/$defs/token" },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}
