{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.incursa.com/protocol-lab/run-plan/v2/run-plan.schema.json",
  "title": "ProtocolLab Run Plan v2",
  "description": "Repeatable ProtocolLab job manifest that pins packages plus immutable scenario, suite, and resolved load-profile contract snapshots.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runPlanId",
    "runPlanVersion",
    "packages",
    "implementationIds",
    "testExecutorIds",
    "protocols",
    "targetMode",
    "targetNetworkMode",
    "requiredCapabilities",
    "loadProfileSnapshot"
  ],
  "properties": {
    "schemaVersion": {
      "const": "protocol-lab-run-plan-v2"
    },
    "runPlanId": {
      "$ref": "#/$defs/token"
    },
    "runPlanVersion": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/packageReference"
      }
    },
    "implementationIds": {
      "$ref": "#/$defs/nonEmptyTokenArray"
    },
    "testExecutorIds": {
      "$ref": "#/$defs/nonEmptyTokenArray"
    },
    "suiteIds": {
      "$ref": "#/$defs/nonEmptyTokenArray"
    },
    "scenarioIds": {
      "$ref": "#/$defs/nonEmptyTokenArray"
    },
    "protocols": {
      "$ref": "#/$defs/nonEmptyTokenArray"
    },
    "targetMode": {
      "type": "string",
      "enum": [
        "implementation-resolved",
        "external"
      ]
    },
    "targetNetworkMode": {
      "type": "string",
      "enum": [
        "published-endpoint",
        "implementation-defined"
      ]
    },
    "requiredCapabilities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/capabilityRequirement"
      }
    },
    "repetitions": {
      "type": "integer",
      "minimum": 1
    },
    "cellOrder": {
      "type": "string",
      "enum": [
        "legacy",
        "round-robin"
      ],
      "description": "Deterministic scheduling policy for the selected cells. Round-robin interleaves implementations by repetition within stable comparison groups."
    },
    "comparisonGroups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/comparisonGroup"
      }
    },
    "specificationCoverage": {
      "$ref": "#/$defs/specificationCoverageSelection",
      "description": "Optional selection of package-provided, hash-pinned specification coverage inputs. This selects existing reviewed mappings and never authors mappings or changes publication, comparability, or ranking semantics."
    },
    "publicationIntent": {
      "type": "string",
      "enum": [
        "non-public",
        "publishable-report"
      ]
    },
    "labels": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "traceReferences": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "notes": {
      "type": "string"
    },
    "loadProfileSnapshot": {
      "$ref": "#/$defs/versionedSnapshot"
    },
    "scenarioSnapshots": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/versionedSnapshot"
      }
    },
    "suiteSnapshots": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/versionedSnapshot"
      }
    }
  },
  "anyOf": [
    {
      "required": [
        "suiteIds"
      ]
    },
    {
      "required": [
        "scenarioIds"
      ]
    }
  ],
  "$defs": {
    "token": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "nonEmptyTokenArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/token"
      }
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "packageReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packageId",
        "packageVersion",
        "sha256"
      ],
      "properties": {
        "packageId": {
          "$ref": "#/$defs/token",
          "description": "Stable public package identity pinned by the run plan. This value is not proof of publisher, namespace, trademark, or package-index ownership."
        },
        "packageVersion": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "capabilityRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/token"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "comparisonGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "groupId"
      ],
      "properties": {
        "groupId": {
          "$ref": "#/$defs/token"
        },
        "suiteIds": {
          "$ref": "#/$defs/nonEmptyTokenArray"
        },
        "scenarioIds": {
          "$ref": "#/$defs/nonEmptyTokenArray"
        },
        "sameExecutorRequired": {
          "type": "boolean"
        },
        "sameLoadProfileRequired": {
          "type": "boolean"
        }
      },
      "anyOf": [
        {
          "required": [
            "suiteIds"
          ]
        },
        {
          "required": [
            "scenarioIds"
          ]
        }
      ]
    },
    "versionedSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "sha256",
        "canonicalization"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/token"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "canonicalization": {
          "type": "string",
          "enum": ["json-sort-keys-utf8-no-whitespace-v1", "yaml-parse-json-sort-keys-utf8-no-whitespace-v1"]
        }
      }
    },
    "specificationCoverageSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "catalogSnapshot",
        "mappingSnapshots",
        "compatibilityPolicy"
      ],
      "properties": {
        "catalogSnapshot": {
          "$ref": "#/$defs/versionedSnapshot"
        },
        "mappingSnapshots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/versionedSnapshot"
          }
        },
        "profileSnapshots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/versionedSnapshot"
          }
        },
        "requirementIds": {
          "$ref": "#/$defs/nonEmptyTokenArray"
        },
        "checkIds": {
          "$ref": "#/$defs/nonEmptyTokenArray"
        },
        "compatibilityPolicy": {
          "type": "string",
          "enum": [
            "require-structured-outcomes",
            "allow-diagnostic-outcomes",
            "mapping-metadata-only"
          ]
        }
      },
      "anyOf": [
        {
          "required": [
            "profileSnapshots"
          ]
        },
        {
          "required": [
            "requirementIds"
          ]
        },
        {
          "required": [
            "checkIds"
          ]
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "scenarioIds"
        ]
      },
      "then": {
        "required": [
          "scenarioSnapshots"
        ]
      }
    },
    {
      "if": {
        "required": [
          "suiteIds"
        ]
      },
      "then": {
        "required": [
          "suiteSnapshots"
        ]
      }
    }
  ]
}
