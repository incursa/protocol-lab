{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.incursa.com/protocol-lab/artifact/v1/artifact-reference.schema.json",
  "title": "ProtocolLab Artifact Reference v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "kind",
    "media_type",
    "path",
    "sha256",
    "size_bytes",
    "created_at_utc",
    "producer",
    "redaction_state",
    "contains_sensitive_data",
    "retention_class",
    "description",
    "tags"
  ],
  "properties": {
    "artifact_id": { "type": "string", "minLength": 1 },
    "kind": {
      "type": "string",
      "enum": ["log", "trace", "metrics", "qlog", "pcap", "stdout", "stderr", "profile", "summary", "report", "raw", "other"]
    },
    "media_type": { "type": "string", "minLength": 1 },
    "path": { "type": "string", "minLength": 1 },
    "uri": { "type": "string", "format": "uri" },
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "size_bytes": { "type": "integer", "minimum": 0 },
    "created_at_utc": { "type": "string", "format": "date-time" },
    "producer": { "$ref": "#/$defs/producer" },
    "redaction_state": { "$ref": "./redaction-state.schema.json" },
    "contains_sensitive_data": { "type": "boolean" },
    "retention_class": {
      "type": "string",
      "enum": ["public", "internal", "temporary", "restricted", "unknown"]
    },
    "description": { "type": "string" },
    "tags": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "redaction_state": {
            "enum": ["producer-declared-safe", "sanitized"]
          }
        },
        "required": ["redaction_state"]
      },
      "then": {
        "properties": {
          "contains_sensitive_data": { "const": false }
        }
      }
    },
    {
      "if": {
        "properties": {
          "retention_class": { "const": "public" }
        },
        "required": ["retention_class"]
      },
      "then": {
        "properties": {
          "contains_sensitive_data": { "const": false }
        }
      }
    }
  ],
  "$defs": {
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["runner", "implementation", "test-executor", "load-generator", "collector", "environment", "other"]
        },
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string" },
        "description": { "type": "string" },
        "telemetry_system": { "type": "string" }
      }
    }
  }
}
