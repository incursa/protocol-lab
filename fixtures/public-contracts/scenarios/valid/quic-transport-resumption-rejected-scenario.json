{
  "schemaVersion": "1.0",
  "id": "quic.transport.resumption-rejected",
  "title": "QUIC Resumption Rejected",
  "name": "QUIC Resumption Rejected",
  "family": "quic.transport",
  "description": "Validate that a QUIC server rejects session resumption and falls back to a fresh handshake without attempting 0-RTT early data.",
  "status": "stable",
  "kind": "protocolValidation",
  "layer": "transport",
  "protocol": "quic",
  "roles": [
    "server"
  ],
  "requires": {
    "capabilities": [
      "quic.server",
      "quic.resumption"
    ],
    "protocols": [
      "quic"
    ],
    "roles": [
      "server"
    ]
  },
  "trafficShape": "handshake-only",
  "implementationRole": "server",
  "requiredCapabilities": [
    "quicTransport",
    "quicHandshake",
    "quicResumption"
  ],
  "quicTransport": {
    "behavior": "resumption-rejected",
    "connectionCount": 1,
    "streamType": "none",
    "streamCount": 0,
    "payloadDirection": "none",
    "openPattern": "sequential",
    "expectedBytes": 0
  },
  "validation": {
    "required": true,
    "checks": [
      "resumption-attempt-rejected",
      "fresh-handshake-completes-after-rejection",
      "zero-early-data-attempted",
      "protocol:quic"
    ],
    "quic": {
      "handshakeMustComplete": true,
      "session": {
        "resumptionState": "rejected",
        "earlyData": "not-attempted",
        "replaySafety": "not-applicable"
      }
    }
  },
  "benchmark": {
    "warmupSeconds": 5,
    "durationSeconds": 30,
    "repetitions": 1,
    "connections": [
      1
    ],
    "streamsPerConnection": [
      0
    ]
  },
  "benchmarkCompat": {
    "compatibleLoadShapes": [
      "quic-resumption",
      "smoke",
      "regression",
      "comparison"
    ],
    "primaryMetrics": [
      "handshakeDurationP50",
      "handshakeDurationP95",
      "connectionSuccessRate",
      "errorRate"
    ]
  },
  "artifacts": {
    "required": [
      "validation.json",
      "result.json"
    ],
    "optional": [
      "protocol-diagnostic-artifact",
      "counters"
    ]
  },
  "networkProfile": "loss-1pct",
  "requiredMetrics": [
    "quic.handshake.durationMs",
    "quic.connection.successCount"
  ],
  "artifactRequirements": [
    "load-generator.stdout.txt",
    "load-generator.stderr.txt",
    "protocol-diagnostic-artifact"
  ],
  "tags": [
    "phase6",
    "quic",
    "handshake",
    "resumption",
    "rejected"
  ]
}
