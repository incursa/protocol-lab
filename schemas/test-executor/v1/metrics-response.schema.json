{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProtocolLab Test Executor Contract v1 Metrics Response",
  "type": "object",
  "additionalProperties": false,
  "required": ["session", "availability", "metrics"],
  "properties": {
    "session": { "$ref": "./common.schema.json#/$defs/sessionSummary" },
    "availability": { "$ref": "./common.schema.json#/$defs/resourceAvailability" },
    "capturedAt": { "type": "string", "format": "date-time" },
    "metrics": {
      "type": "array",
      "items": { "$ref": "./common.schema.json#/$defs/metric" }
    },
    "notes": { "$ref": "./common.schema.json#/$defs/stringArray" },
    "operation": { "$ref": "./common.schema.json#/$defs/operationResult" },
    "extensions": { "$ref": "./common.schema.json#/$defs/extensions" }
  }
}
