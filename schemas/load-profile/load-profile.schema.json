{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.incursa.com/protocol-lab/load-profile/load-profile.schema.json",
  "title": "ProtocolLab Load Profile v1",
  "description": "Schema for ProtocolLab load profile definition files.",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "title",
    "status",
    "purpose"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Schema version identifier (e.g., protocol-lab.load-profile.v1)",
      "pattern": "^protocol-lab\\.load-profile\\.v[0-9]+$"
    },
    "id": {
      "type": "string",
      "description": "Stable load profile ID (e.g., smoke, comparison)",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "description": "Human-readable load profile title"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the load profile"
    },
    "status": {
      "type": "string",
      "description": "Profile maturity status",
      "enum": ["stable", "experimental", "deprecated"]
    },
    "purpose": {
      "type": "string",
      "description": "Intended use of this profile",
      "enum": ["smoke", "diagnostic", "regression", "comparison", "stress", "soak", "publishable-benchmark"]
    },
    "durationSeconds": {
      "type": "integer",
      "description": "Benchmark duration in seconds",
      "minimum": 1
    },
    "warmupSeconds": {
      "type": "integer",
      "description": "Warmup duration in seconds",
      "minimum": 0
    },
    "cooldownSeconds": {
      "type": "integer",
      "description": "Cooldown wait between repetitions in seconds",
      "minimum": 0
    },
    "repetitions": {
      "type": "integer",
      "description": "Number of repetitions",
      "minimum": 1
    },
    "traffic": {
      "type": "object",
      "description": "Traffic-level settings",
      "properties": {
        "totalRequests": {
          "type": "integer",
          "description": "Total request count (null = duration-based)"
        },
        "requestRateLimit": {
          "type": "integer",
          "description": "Request rate limit per second (null = unlimited)"
        }
      }
    },
    "http1": {
      "type": "object",
      "description": "HTTP/1 profile settings",
      "properties": {
        "connections": { "type": "integer" },
        "concurrency": { "type": "integer" },
        "requestTimeoutSeconds": { "type": "integer" }
      }
    },
    "http": {
      "type": "object",
      "description": "Legacy HTTP/1 profile settings key retained for load-profile v1 compatibility",
      "properties": {
        "connections": { "type": "integer" },
        "concurrency": { "type": "integer" },
        "requestTimeoutSeconds": { "type": "integer" }
      }
    },
    "http2": {
      "type": "object",
      "description": "HTTP/2 profile settings",
      "additionalProperties": false,
      "properties": {
        "connections": {
          "type": "integer",
          "minimum": 1,
          "description": "Requested simultaneously established HTTP/2 connections."
        },
        "concurrency": {
          "type": "integer",
          "minimum": 1,
          "description": "Requested global maximum in-flight HTTP operations across all connections; this value is not multiplied by connections or streamsPerConnection."
        },
        "streamsPerConnection": {
          "type": "integer",
          "minimum": 1,
          "description": "Per-connection in-flight stream cap; this is capacity, not a claim that every connection observed the cap."
        },
        "operationDistribution": {
          "type": "string",
          "enum": ["balanced-round-robin"],
          "description": "Assignment policy for new operations across usable connections while stream capacity permits."
        },
        "requestTimeoutSeconds": { "type": "integer", "minimum": 1 }
      }
    },
    "http3": {
      "type": "object",
      "description": "HTTP/3 profile settings",
      "properties": {
        "connections": { "type": "integer" },
        "concurrency": { "type": "integer" },
        "streamsPerConnection": { "type": "integer" },
        "requestTimeoutSeconds": { "type": "integer" }
      }
    },
    "quic": {
      "type": "object",
      "description": "QUIC transport profile settings",
      "properties": {
        "connections": { "type": "integer" },
        "streamsPerConnection": { "type": "integer" },
        "streamBytes": { "type": "integer" },
        "connectionTimeoutSeconds": { "type": "integer" },
        "idleTimeoutSeconds": { "type": "integer" }
      }
    },
    "tls": {
      "type": "object",
      "description": "TLS lifecycle and transfer load settings.",
      "additionalProperties": false,
      "properties": {
        "connections": { "type": "integer", "minimum": 1 },
        "concurrency": { "type": "integer", "minimum": 1 },
        "handshakesPerConnection": { "type": "integer", "minimum": 1 },
        "applicationDataBytes": { "type": "integer", "minimum": 0 },
        "connectionTimeoutSeconds": { "type": "integer", "minimum": 1 }
      }
    },
    "evidence": {
      "type": "object",
      "description": "Evidence tier requirements",
      "properties": {
        "minimumTier": {
          "type": "string",
          "enum": ["smoke", "diagnostic", "regression", "comparison", "soak", "publishable"]
        },
        "publishable": {
          "type": "boolean"
        }
      }
    },
    "artifacts": {
      "type": "object",
      "description": "Declared artifact paths",
      "properties": {
        "required": {
          "type": "array",
          "items": { "type": "string" }
        },
        "optional": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"id": {"const": "http2-comparison"}}, "required": ["id"]},
      "then": {
        "required": ["durationSeconds", "warmupSeconds", "repetitions", "http2"],
        "properties": {
          "durationSeconds": {"const": 30},
          "warmupSeconds": {"const": 10},
          "repetitions": {"const": 3},
          "http2": {
            "required": ["connections", "concurrency", "streamsPerConnection", "operationDistribution", "requestTimeoutSeconds"],
            "properties": {
              "connections": {"const": 16},
              "concurrency": {"const": 128},
              "streamsPerConnection": {"const": 8},
              "operationDistribution": {"const": "balanced-round-robin"},
              "requestTimeoutSeconds": {"const": 10}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"id": {"const": "tls-handshake-smoke"}}, "required": ["id"]},
      "then": {
        "required": ["durationSeconds", "warmupSeconds", "repetitions", "tls"],
        "properties": {
          "durationSeconds": {"const": 5},
          "warmupSeconds": {"const": 1},
          "repetitions": {"const": 1},
          "tls": {
            "required": ["connections", "concurrency", "handshakesPerConnection", "applicationDataBytes", "connectionTimeoutSeconds"],
            "properties": {
              "connections": {"const": 1},
              "concurrency": {"const": 1},
              "handshakesPerConnection": {"const": 1},
              "applicationDataBytes": {"const": 0},
              "connectionTimeoutSeconds": {"const": 5}
            }
          }
        }
      }
    }
  ]
}
