{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.incursa.com/protocol-lab/tls/v1/tls-profile.schema.json",
  "title": "ProtocolLab TLS Profile v1",
  "description": "Exact TLS 1.3 identity, cryptographic, certificate-shape, and measurement-boundary profile shared by TLS performance scenarios.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "profileId", "tlsVersion", "serverName", "alpn", "cipherSuite", "keyExchangeGroup", "signatureScheme", "peerAuthentication", "certificate", "evidence"],
  "properties": {
    "schemaVersion": {"const": "protocol-lab.tls-profile.v1"},
    "profileId": {"const": "plab-tls13-p256-v1"},
    "tlsVersion": {"const": "tls1.3"},
    "serverName": {"const": "tls.plab.test"},
    "alpn": {"const": "protocol-lab-tls"},
    "cipherSuite": {"const": "TLS_AES_128_GCM_SHA256"},
    "keyExchangeGroup": {"const": "x25519"},
    "signatureScheme": {"const": "ecdsa_secp256r1_sha256"},
    "peerAuthentication": {"const": "server-certificate-required"},
    "certificate": {
      "type": "object", "additionalProperties": false,
      "required": ["profileId", "leafKeyAlgorithm", "leafNamedCurve", "dnsSubjectAlternativeName", "sentCertificateCount", "trustAnchorSent", "trustModel", "mustBeValidAtExecution", "provisioningMeasured", "exactDerHashRequiredForComparison", "privateKeyPublication"],
      "properties": {
        "profileId": {"const": "plab-single-leaf-p256-v1"}, "leafKeyAlgorithm": {"const": "ecdsa"},
        "leafNamedCurve": {"const": "secp256r1"}, "dnsSubjectAlternativeName": {"const": "tls.plab.test"},
        "sentCertificateCount": {"const": 1}, "trustAnchorSent": {"const": false},
        "trustModel": {"const": "configured-test-trust-anchor"}, "mustBeValidAtExecution": {"const": true},
        "provisioningMeasured": {"const": false}, "exactDerHashRequiredForComparison": {"const": true},
        "privateKeyPublication": {"const": "forbidden"}
      }
    },
    "evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["negotiatedParametersRequired", "leafCertificateDerSha256Required", "platformProvenanceRequired", "accelerationProvenanceRequired"],
      "properties": {
        "negotiatedParametersRequired": {"const": true}, "leafCertificateDerSha256Required": {"const": true},
        "platformProvenanceRequired": {"const": true}, "accelerationProvenanceRequired": {"const": true}
      }
    }
  }
}
