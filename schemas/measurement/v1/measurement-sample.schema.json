{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.incursa.com/protocol-lab/measurement/v1/measurement-sample.schema.json",
  "title": "ProtocolLab Measurement Sample v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["metric_name", "metric_kind", "unit", "timestamp_utc", "source", "scope", "collector_id", "tags", "provenance", "warnings"],
  "properties": {
    "metric_name": { "type": "string", "minLength": 1 },
    "metric_kind": {
      "type": "string",
      "enum": ["counter", "gauge", "histogram", "summary", "event", "state"]
    },
    "value": {
      "type": ["number", "string", "boolean", "object", "array", "null"]
    },
    "unit": { "type": "string", "minLength": 1 },
    "timestamp_utc": { "type": "string", "format": "date-time" },
    "interval_ms": { "type": "integer", "minimum": 0 },
    "aggregation": { "type": "string", "minLength": 1 },
    "source": { "$ref": "#/$defs/source" },
    "scope": { "$ref": "#/$defs/scope" },
    "collector_id": { "type": "string", "minLength": 1 },
    "tags": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
    },
    "provenance": { "$ref": "#/$defs/provenance" },
    "external_correlation": { "$ref": "#/$defs/external_correlation" },
    "warnings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "scope": {
      "type": "string",
      "enum": ["runner", "implementation", "test-executor", "load-generator", "environment", "protocol", "artifact", "other"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "$ref": "#/$defs/scope" },
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "telemetry_system": { "type": "string", "minLength": 1 }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "required": ["observed_by", "method"],
      "properties": {
        "observed_by": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "confidence": {
          "type": "string",
          "enum": ["declared", "observed", "derived", "estimated", "unknown"]
        }
      }
    },
    "external_correlation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "system": { "type": "string" },
        "correlation_id": { "type": "string" },
        "trace_id": { "type": "string" },
        "span_id": { "type": "string" }
      }
    }
  }
}
