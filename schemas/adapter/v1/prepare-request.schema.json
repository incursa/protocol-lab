{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProtocolLab Adapter Contract v1 Prepare Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scenarioId",
    "scenarioVersion",
    "role",
    "scenarioDocument",
    "requestedEndpointBindings",
    "runId",
    "cellId",
    "artifactOutputExpectations"
  ],
  "properties": {
    "scenarioId": { "type": "string", "minLength": 1 },
    "scenarioVersion": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "minLength": 1 },
    "scenarioDocument": {
      "description": "Opaque scenario document supplied by the runner."
    },
    "requestedEndpointBindings": {
      "type": "array",
      "items": { "$ref": "./common.schema.json#/$defs/endpointBinding" }
    },
    "runId": { "type": "string", "minLength": 1 },
    "cellId": { "type": "string", "minLength": 1 },
    "artifactOutputExpectations": {
      "type": "array",
      "items": { "$ref": "./common.schema.json#/$defs/artifactExpectation" }
    },
    "extensions": { "$ref": "./common.schema.json#/$defs/extensions" }
  }
}
