{
  "schemaVersion": "2.0",
  "id": "tls.handshake.full",
  "title": "TLS 1.3 Full Handshake",
  "description": "Establish a fresh authenticated TLS 1.3 session without resumption, early data, or application data.",
  "status": "draft",
  "kind": "workload",
  "layer": "transport",
  "protocol": "tls",
  "family": "tls",
  "roles": [
    "client",
    "server"
  ],
  "requires": {
    "capabilities": [
      "tls.client",
      "tls.server",
      "tls.handshake.full"
    ],
    "protocols": [
      "tls"
    ],
    "roles": [
      "client",
      "server"
    ]
  },
  "trafficShape": "handshake-only",
  "tls": {
    "version": "tls1.3",
    "mode": "full-handshake",
    "sessionReuse": "none",
    "earlyData": "not-attempted",
    "applicationDataBytes": 0,
    "sni": "tls.protocol-lab.test",
    "alpn": "h2",
    "certificateProfile": "plab-single-leaf-p256-v1",
    "expectedCertificateDerSha256": "da2726daa05ed45fb402c07ad30397eacaf2b1e7613429e895616fc64cf04d27",
    "expectedCertificateSpkiSha256": "bdfb8c50b2fef0bea004230ce8839d1b1bf7c7dc1b058b8f3c4887d41a9c9dd8"
  },
  "measurementBoundaries": {
    "tlsHandshakeLatency": "client-tls-handshake-start-to-authenticated-tls-complete",
    "connectionAndHandshakeLatency": "tcp-connect-start-to-authenticated-tls-complete",
    "excludedFromTlsHandshakeLatency": [
      "dns-resolution",
      "tcp-establishment",
      "target-startup",
      "certificate-generation",
      "artifact-writing"
    ]
  },
  "validation": {
    "required": true,
    "checks": [
      "protocol:tls1.3",
      "no-fallback",
      "handshake-complete",
      "authenticated-peer",
      "fresh-session",
      "no-early-data",
      "application-data-bytes:0",
      "sni-match",
      "alpn:protocol-lab-tls",
      "certificate-profile-match",
      "certificate-der-sha256-match",
      "certificate-spki-sha256-match",
      "selected-executor-match",
      "selected-load-generator-match",
      "zero-unexpected-failures",
      "zero-timeouts"
    ]
  },
  "benchmarkCompat": {
    "compatibleLoadShapes": [
      "smoke",
      "diagnostic",
      "comparison",
      "connection-churn"
    ],
    "primaryMetrics": [
      "handshakesPerSecond",
      "tlsHandshakeLatencyP50",
      "tlsHandshakeLatencyP95",
      "tlsHandshakeLatencyP99",
      "failedOperations",
      "timedOutOperations"
    ]
  },
  "requiredMetrics": [
    "handshakesPerSecond",
    "tlsHandshakeLatencyMean",
    "tlsHandshakeLatencyP50",
    "tlsHandshakeLatencyP75",
    "tlsHandshakeLatencyP90",
    "tlsHandshakeLatencyP95",
    "tlsHandshakeLatencyP99",
    "completedOperations",
    "failedOperations",
    "timedOutOperations"
  ],
  "artifacts": {
    "required": [
      "validation.json",
      "protocol-proof.json",
      "tls-negotiation.json",
      "tls-topology.json",
      "result.json",
      "load.stdout.log",
      "load.stderr.log"
    ],
    "optional": [
      "connection-and-handshake-latency.json",
      "target-telemetry.json",
      "load-generator-telemetry.json"
    ]
  },
  "networkProfile": "clean",
  "tags": [
    "tls",
    "tls1.3",
    "handshake",
    "full"
  ]
}
